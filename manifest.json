{
	"manifest_version": 3,
	"name": "ChatGPT Prompt Logger (Local)",
	"description": "Captures prompts you send on ChatGPT and stores them locally in your browser.",
	"version": "1.0.0",
	"permissions": [
		"storage"
	],
	"host_permissions": [
		"https://chatgpt.com/*",
		"https://chat.openai.com/*"
	],
	"content_scripts": [
		{
			"matches": [
				"https://chatgpt.com/*",
				"https://chat.openai.com/*"
			],
			"js": [
				"content.js"
			],
			"run_at": "document_idle"
		}
	],
	"action": {
		"default_popup": "index.html",
		"default_title": "Prompt Logger"
	}
}
